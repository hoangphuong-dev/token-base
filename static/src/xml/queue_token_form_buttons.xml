<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-extend="FormView.buttons">
        <t t-jquery="button.o_form_button_create" t-operation="after">
            <t t-if="widget.modelName == 'queue.token'">
                <button type="button" class="btn btn-secondary o_queue_print_token">
                    <i class="fa fa-print"/> In Token
                </button>
                <button type="button" class="btn btn-danger o_queue_emergency_override">
                    <i class="fa fa-exclamation-triangle"/> Đánh Dấu Khẩn Cấp
                </button>
            </t>
        </t>
    </t>
</templates>