<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_queue_dashboard" model="ir.ui.view">
        <field name="name">queue.dashboard.kanban</field>
        <field name="model">queue.room</field>
        <field name="arch" type="xml">
            <kanban class="oe_background_grey" create="false">
                <field name="name" />
                <field name="service_id" />
                <field name="state" />
                <field name="queue_length" />
                <field name="estimated_wait_time" />
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click container">
                            <div class="row">
                                <div class="col-6">
                                    <strong>
                                        <field name="name" />
                                    </strong>
                                </div>
                                <div class="col-6">
                                    <span
                                        t-attf-class="float-right badge badge-pill
                                            #{record.state.raw_value == 'open' ? 'badge-success' : ''}
                                            #{record.state.raw_value == 'closed' ? 'badge-danger' : ''}
                                            #{record.state.raw_value == 'maintenance' ? 'badge-warning' : ''}">
                                        <field name="state" />
                                    </span>
                                </div>
                            </div>
                            <div class="row mt8">
                                <div class="col-12">
                                    <field name="service_id" />
                                </div>
                            </div>
                            <div class="row mt8">
                                <div class="col-6">
                                    <span>Hàng đợi:</span>
                                    <span class="badge badge-info">
                                        <field name="queue_length" />
                                    </span>
                                </div>
                                <div class="col-6">
                                    <span>Thời gian chờ:</span>
                                    <span
                                        t-attf-class="badge #{record.estimated_wait_time.raw_value &gt; 30 ? 'badge-danger' : record.estimated_wait_time.raw_value &gt; 15 ? 'badge-warning' : 'badge-success'}">
                                        <field name="estimated_wait_time" /> phút </span>
                                </div>
                            </div>
                            <div class="row mt8">
                                <div class="col-12">
                                    <button name="action_view_tokens" type="object"
                                        class="btn btn-sm btn-primary">
                                        Xem Token
                                    </button>
                                    <button name="action_open_room" type="object"
                                        class="btn btn-sm btn-success"
                                        invisible="[('state', '=', 'open')]">
                                        Mở Phòng
                                    </button>
                                    <button name="action_close_room" type="object"
                                        class="btn btn-sm btn-danger"
                                        invisible="[('state', '=', 'closed')]">
                                        Đóng Phòng
                                    </button>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_queue_dashboard" model="ir.actions.act_window">
        <field name="name">Bảng Điều Khiển Hàng Đợi</field>
        <field name="res_model">queue.room</field>
        <field name="view_mode">kanban,form</field>
        <field name="view_id" ref="view_queue_dashboard" />
        <field name="context">{'search_default_open_rooms': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo phòng đầu tiên
            </p>
            <p>
                Tạo các phòng để bắt đầu quản lý hàng đợi khám sức khỏe.
            </p>
        </field>
    </record>

    <!-- Dashboard Filter -->
    <record id="view_queue_room_search" model="ir.ui.view">
        <field name="name">queue.room.search</field>
        <field name="model">queue.room</field>
        <field name="arch" type="xml">
            <search string="Phòng">
                <field name="name" />
            </search>
        </field>
    </record>
</odoo>